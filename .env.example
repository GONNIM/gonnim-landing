# Resend (상담 요청 폼 백엔드 · 필수)
# 발급: https://resend.com/api-keys
RESEND_API_KEY=

# 상담 요청 알림 발신·수신 주소 (기본값 hi@gonnim.dev)
CONTACT_FROM_EMAIL=hi@gonnim.dev
CONTACT_TO_EMAIL=hi@gonnim.dev

# 이메일 도메인 MX 실 검증 (선택 · true 로 활성)
# 활성 시 폼 제출 지연 100~300ms · 유령 도메인 배제
CONTACT_VERIFY_MX=

# Upstash Redis · Rate limit (선택 · 없으면 skip)
# https://console.upstash.com — Regional · ap-northeast-1
# 정책: IP 당 5분 3회
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile · 봇 방지 (선택 · 없으면 skip)
# https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_ prefix 는 client 노출용 (그대로 유지)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 로컬 개발: .env.local 에 위 값을 채우면 next dev 자동 로드
# 프로덕션(Vercel): Vercel Dashboard → Project Settings → Environment Variables
