# Resend (상담 요청 폼 백엔드 · 필수)
# 발급: https://resend.com/api-keys
RESEND_API_KEY=

# 상담 요청 알림 발신·수신 주소 (기본값 hi@gonnim.dev)
CONTACT_FROM_EMAIL=hi@gonnim.dev
CONTACT_TO_EMAIL=hi@gonnim.dev

# 이메일 도메인 MX 실 검증 (선택 · true 로 활성)
# 활성 시 폼 제출 지연 100~300ms · 유령 도메인 배제
CONTACT_VERIFY_MX=

# Upstash Redis · Rate limit (선택 · 없으면 skip)
# https://console.upstash.com — Regional · ap-northeast-1
# 정책: IP 당 5분 3회
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile · 봇 방지 (선택 · 없으면 skip)
# https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_ prefix 는 client 노출용 (그대로 유지)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================
# Sprint Radar (2026-07-13 · Sprint W1)
# ============================================================

# Supabase (필수)
# https://supabase.com/dashboard/project/{project-id}/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 · 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron 인증 (선택 · 로컬 개발 시 비워도 됨)
# Vercel 배포 후 Vercel Dashboard에서 자동 주입되는 CRON_SECRET 활용 권장
CRON_SECRET=

# Radar 관리자 이메일 allow-list (콤마 구분 · 필수 · /api/radar/signup 게이트)
# 미설정 시 signup 503 · 등록된 이메일만 가입/비밀번호 갱신 가능
RADAR_ADMIN_EMAILS=hi@gonnim.dev

# z.ai GLM · Day 4 · /api/radar/generate-draft 지원 초안 자동 생성
# https://z.ai/manage-apikey/apikey-list
# 미설정 시 초안 생성 API 503 · 대시보드 나머지 기능은 정상
ZAI_API_KEY=

# GLM 모델 (선택 · 기본 glm-5.2 · 1M 컨텍스트 · 128K 출력)
# 다른 옵션: glm-4.5 · glm-4.5-air · glm-4.5-flash 등
ZAI_MODEL=

# Base URL 오버라이드 (선택 · 기본 https://api.z.ai/api/paas/v4)
ZAI_BASE_URL=

# ============================================================
# 로컬 개발: .env.local 에 위 값을 채우면 next dev 자동 로드
# 프로덕션(Vercel): Vercel Dashboard → Project Settings → Environment Variables
