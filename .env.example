# Resend (상담 요청 폼 백엔드)
# 발급: https://resend.com/api-keys
# 도메인 인증 완료 후에만 hi@gonnim.dev 발신 가능 (Cloudflare DNS TXT 3건)
RESEND_API_KEY=

# 상담 요청 알림 수신·발신 주소 (기본값 hi@gonnim.dev)
CONTACT_FROM_EMAIL=hi@gonnim.dev
CONTACT_TO_EMAIL=hi@gonnim.dev

# 로컬 개발: .env.local 에 위 값을 채워 놓으면 next dev 가 자동 로드
# 프로덕션(Vercel): Vercel Dashboard → Project Settings → Environment Variables
